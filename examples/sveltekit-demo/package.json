{
  "name": "easyauth-sveltekit-demo",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "server": "node server/index.js"
  },
  "dependencies": {
    "@easyauth/backend": "workspace:*",
    "@easyauth/frontend": "workspace:*",
    "@easyauth/shared": "workspace:*",
    "better-auth": "1.2.7",
    "fastify": "5.2.2"
  },
  "devDependencies": {
    "@sveltejs/adapter-vercel": "^5.10.3",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "svelte": "5.55.5",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^3.4.17",
    "tslib": "^2.8.1",
    "typescript": "6.0.3",
    "vite": "^6.0.0"
  }
}
