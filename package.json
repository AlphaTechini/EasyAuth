{
  "name": "easyauth-sdk",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "pretypecheck": "pnpm --filter @easyauth/shared build",
    "typecheck": "pnpm -r run typecheck",
    "verify": "node scripts/verify.mjs"
  },
  "pnpm": {
    "overrides": {
      "cookie": "0.7.2",
      "esbuild": "0.25.12",
      "vite": "6.4.2"
    }
  },
  "devDependencies": {
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitepress": "1.6.4"
  }
}
